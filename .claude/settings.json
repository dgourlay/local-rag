{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-and-typecheck.sh",
            "timeout": 600,
            "statusMessage": "Linting and type-checking..."
          }
        ]
      }
    ]
  }
}
